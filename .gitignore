# ============================================================
#  IMPACT - Intelligent Municipal Action & City Triage
#  .gitignore — comprehensive, production-safe
# ============================================================

# ─── ENVIRONMENT / SECRETS ──────────────────────────────────
# NEVER commit these — they contain DB credentials and JWT keys
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example


# ─── NODE / NPM ─────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# Lock files are OK to commit; skip only if you prefer not to
# package-lock.json
# yarn.lock

# npm debug / error logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log


# ─── VITE / REACT BUILD OUTPUT ──────────────────────────────
# 'dist' is generated by `npm run build` — NOT needed in repo
# (your hosting platform builds it from source)
client/dist/
client/dist-ssr/
dist/
build/
*.local


# ─── PYTHON / ML SERVER ─────────────────────────────────────
# Virtual environment — huge, built locally with pip install
venv/
.venv/
env/
ENV/
*.egg-info/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ML artefacts — the .pt and .pkl model files MUST be committed
# so the ML server works after deployment. Only ignore the raw
# training image dataset (thousands of images, not needed at runtime).
ML\ Model/dataset/train/
ML\ Model/dataset/valid/
ML\ Model/dataset/test/
ML\ Model/civic_complaints.csv

# Keep all model files — required for inference:
# ML Model/best (1).pt        ← YOLO weights
# ML Model/severity_model.pkl ← NLP severity classifier
# ML Model/category_model.pkl ← NLP category classifier
# ML Model/tfidf_vectorizer.pkl ← TF-IDF vectorizer


# ─── ZIP / ARCHIVES ─────────────────────────────────────────
# The project zip sitting in the root is not source code
*.zip
*.tar.gz
*.rar
*.7z


# ─── OS GENERATED ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ─── EDITOR / IDE ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp


# ─── MISC TEMPORARY / DEBUG FILES ───────────────────────────
# One-off test scripts committed to root during debugging
dbTest.js
dbTest2.js
server/checkCities.js
server/dbTest2.js


# ─── CODE COVERAGE ──────────────────────────────────────────
coverage/
.nyc_output/
